{
  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\mssqllocaldb;Database=EnergyOptimizerDB;Trusted_Connection=true"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Simulation": {
    "IntervalMinutes": 1,
    "EnableSimulation": true
  },
  "Gemini": {
    "ApiKey": "Your-API-KEY",
    "Model": "gemini-2.5-flash",
    "MaxTokens": 4096,
    "Temperature": 0.7,
    "RateLimitPerMinute": 60,
    "EnableCaching": true,
    "CacheDurationMinutes": 30

  },
  "AIAnalysis": {
    "IntervalHours": 24,
    "EnableBackgroundAnalysis": true,
    "MaxAnomaliesPerDevice": 10,
    "RecommendationExpiryDays": 30
  },
  "PatternDetection": {
    "MinDataPointsForAnalysis": 100,
    "PeakHoursThreshold": 0.7,
    "AnomalyThreshold": 2.5,
    "AnalysisIntervalHours": 24,
    "PatternDetectionEnabled": true
  }

}

