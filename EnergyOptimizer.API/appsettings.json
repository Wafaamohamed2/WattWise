{
  "ConnectionStrings": {
    "DefaultConnection": "Server=.;Database=EnergyOptimizer;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Simulation": {
    "IntervalMinutes": 1,
    "EnableSimulation": true
  },
  "Gemini": {
    "ApiKey": "",
    "Model": "gemini-2.5-flash-lite",
    "MaxTokens": 4096,
    "Temperature": 0.7,
    "RateLimitPerMinute": 60,
    "EnableCaching": true,
    "CacheDurationMinutes": 3000
  },
  "AIAnalysis": {
    "IntervalHours": 24,
    "EnableBackgroundAnalysis": true,
    "MaxAnomaliesPerDevice": 10,
    "RecommendationExpiryDays": 30
  },
  "PatternDetection": {
    "MinDataPointsForAnalysis": 100,
    "PeakHoursThreshold": 0.7,
    "AnomalyThreshold": 2.5,
    "AnalysisIntervalHours": 24,
    "PatternDetectionEnabled": true
  },

  "Jwt": {
    "Key": "",
    "Issuer": "EnergyOptimizerAPI",
    "Audience": "EnergyOptimizerUsers",
    "DurationInMinutes": 60
  },
  "AllowedOrigins": [
    "https://localhost:7083",
    "http://localhost:5167"
  ]
}



